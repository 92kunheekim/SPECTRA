python train_seq.py --model_type seq \
    --csv ../data/training_df.csv \
    --pdb_dir ${SPECTRA_ROOT}/data/STAG-LLM/data/top_structures/ \
    --folds_json ${SPECTRA_ROOT}/app/ImmunoStruct/data/leakage_free/training_data_split_leakfree.json \
    --fold $((LSB_JOBINDEX - 1)) \
    --output_dir ${SPECTRA_ROOT}/project/TCRpMHC/outputs/SeqModel \
    --cache_dir ${SPECTRA_ROOT}/data/STAG-LLM/immunostruct_cache3 \
    --esm_checkpoint ${SPECTRA_ROOT}/data/models/facebook/esm2_t6_8M_UR50D \
    --freeze_esm \
    --phase2_unfreeze_layers 4 \
    --phase2_epochs 20 \
    --phase2_lr 5e-5 \
    --batch_size 32 \
    --use_lora --lora_rank 8 --lora_n_layers 4 --lora_lr 2e-4 --lora_pmhc

